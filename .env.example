# Shared local env — copy to .env or apps/blog/.env.local
DATABASE_URL=postgresql://everythingme:everythingme@localhost:5433/everythingme

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Match the port your blog dev server uses
BETTER_AUTH_URL=http://localhost:3000

# Optional — for Unsplash photo picker in /admin
UNSPLASH_ACCESS_KEY=
